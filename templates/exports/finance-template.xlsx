// templates/exports/finance-template.xlsx
// Financial data import/export template structure

/*
Fee Structure Import Template:

Columns:
- Fee Category Name (required)
- Fee Type (Tuition/Activity/Transport/Meals/Uniform/Supplies/Other)
- Default Amount (RWF) (required)
- Reset Frequency (one_time/termly/monthly/annual)
- Description (optional)

Sample:
Tuition Fees,Tuition,150000,termly,Regular tuition fee
Activity Fees,Activity,25000,termly,Extracurricular activities
Transport Fees,Transport,50000,termly,Bus service
*/

/*
Payment Import Template:

Columns:
- Student Code (required)
- Amount (RWF) (required)
- Payment Date (YYYY-MM-DD) (required)
- Payment Method (Cash/Mobile-Money/Bank Transfer/Cheque)
- Reference (optional)
- Notes (optional)

Sample:
STU001,50000,2026-01-15,Cash,REF001,Term 1 tuition partial payment
STU002,150000,2026-01-20,Bank Transfer,TRX123,Full payment
*/

export function generateFeeStructureImportTemplate() {
    const template = [
        {
            'Fee Category Name': 'Tuition Fees',
            'Fee Type': 'Tuition',
            'Default Amount (RWF)': '150000',
            'Reset Frequency': 'termly',
            'Description': 'Regular tuition fee per term'
        },
        {
            'Fee Category Name': 'Activity Fees',
            'Fee Type': 'Activity',
            'Default Amount (RWF)': '25000',
            'Reset Frequency': 'termly',
            'Description': 'Extracurricular activities'
        },
        {
            'Fee Category Name': 'Transport Fees',
            'Fee Type': 'Transport',
            'Default Amount (RWF)': '50000',
            'Reset Frequency': 'termly',
            'Description': 'School bus service'
        }
    ];
    return template;
}

