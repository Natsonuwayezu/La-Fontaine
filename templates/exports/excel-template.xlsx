// templates/exports/excel-template.xlsx
// This file would be created using Excel or SheetJS
// Structure for student import template:

/*
Columns:
- First Name (required)
- Last Name (required)
- Class (required) - must match existing class name
- Gender (optional) - Male/Female
- Date of Birth (optional) - YYYY-MM-DD format
- Guardian Name (required)
- Guardian Phone (optional)
- Guardian Email (optional)
- Enrollment Date (optional) - YYYY-MM-DD format
- Nationality (optional)
- Notes (optional)

Sample row:
John,Doe,PRIMARY 4,Male,2015-06-15,Jane Doe,+250788123456,jane@email.com,2026-01-15,Rwandan,
*/

// For programmatic creation, use this function:
export function generateStudentImportTemplate() {
    const template = [
        {
            'First Name': 'John',
            'Last Name': 'Doe',
            'Class': 'PRIMARY 4',
            'Gender': 'Male',
            'Date of Birth': '2015-06-15',
            'Guardian Name': 'Jane Doe',
            'Guardian Phone': '+250788123456',
            'Guardian Email': 'jane@email.com',
            'Enrollment Date': '2026-01-15',
            'Nationality': 'Rwandan',
            'Notes': ''
        }
    ];
    return template;
}